# APP_URL: The public URL where this app is hosted.
# Used for email links (e.g., "Go to Admin Panel" button).
APP_URL="https://your-domain.com"

# ─── SECURITY (REQUIRED) ───────────────────────────────────
# Both are REQUIRED — the server will refuse to start without JWT_SECRET.

# Generate with: openssl rand -hex 32
JWT_SECRET="CHANGE_ME_generate_a_random_secret"

# The admin panel login password. Pick a strong, unique password.
ADMIN_PASSWORD="feraverto"

# Gemini API Key for automatic translation (obtain from Google AI Studio)
GEMINI_API_KEY=

# ─── EMAIL SMTP CONFIGURATION ───────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM='"Velvet Budapest" <noreply@velvetnails.com>'
ADMIN_EMAIL="admin@velvetnails.com"
